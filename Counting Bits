class Solution {
public:
    int convert(int n) {
        int count = 0;
        while (n >= 1) {
            if (n % 2 == 1)
                count++;
            n /= 2;
        }
        return count;
    }
    vector<int> countBits(int n) {
        vector<int> res;
        for (int i = 0; i <= n; i++) {
            int ans = convert(i);
            res.push_back(ans);
        }
        return res;
    }
};
